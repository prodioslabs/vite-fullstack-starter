{
  "name": "vite-fullstack-starter",
  "version": "0.1",
  "description": "React fullstack starter with vite, nestjs and ts-rest",
  "private": true,
  "scripts": {
    "clean": "rimraf node_modules **/*/node_modules",
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck",
    "typecheck:watch": "turbo typecheck:watch",
    "version:match": "tsx scripts/version.match.ts"
  },
  "keywords": [
    "vite",
    "nestjs",
    "react",
    "ts-rest",
    "starter"
  ],
  "author": "Team Prodios",
  "devDependencies": {
    "@repo/config": "workspace:*",
    "@types/node": "24.5.1",
    "rimraf": "^6.0.1",
    "tsx": "^4.20.5",
    "turbo": "2.5.6",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.6",
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "@babel/*",
        "expo-modules-*",
        "typescript"
      ]
    }
  },
  "dependencies": {
    "zod": "4.1.9"
  }
}
