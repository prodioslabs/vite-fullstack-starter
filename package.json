{
  "name": "vite-fullstack-starter",
  "type": "module",
  "description": "A fullstack starter template using Tanstack Router and Hono",
  "private": true,
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/**",
    "packages/**"
  ],
  "scripts": {
    "clean": "rimraf node_modules **/*/node_modules **/*/dist",
    "prematch-versions": "bun install",
    "match-versions": "bun run scripts/match-versions.ts",
    "lint:root": "eslint --fix --cache --no-error-on-unmatched-pattern *.{ts,js} scripts/**/*.{ts,js}",
    "lint:workspace": "turbo run lint --ui=stream",
    "lint": "concurrently \"bun run lint:root\" \"bun run lint:workspace\"",
    "format:root": "prettier --write --cache --no-error-on-unmatched-pattern --ignore-path ./.gitignore *.{ts,js,json,md} scripts/**/*.{ts,js,json,md}",
    "format:workspace": "turbo run format --ui=stream",
    "format": "concurrently \"bun run format:root\" \"bun run format:workspace\"",
    "typecheck": "turbo run typecheck --ui=stream",
    "typecheck:watch": "turbo run typecheck:watch",
    "dev": "turbo run dev",
    "build": "turbo build",
    "db:generate": "bun --filter=@repo/server db:generate",
    "db:migrate": "bun --filter=@repo/server db:migrate",
    "db:seed": "bun --filter=@repo/server db:seed"
  },
  "dependencies": {
    "@clack/prompts": "1.5.1",
    "picocolors": "1.1.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@repo/config": "workspace:*",
    "@types/bun": "1.3.14",
    "@types/node": "25.9.3",
    "concurrently": "10.0.3",
    "eslint": "10.5.0",
    "prettier": "3.8.4",
    "rimraf": "6.1.3",
    "turbo": "2.9.18"
  },
  "peerDependencies": {
    "typescript": "6.0.3"
  }
}
