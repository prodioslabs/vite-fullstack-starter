{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "lint": { "cache": true },
    "format": { "cache": true },
    "typecheck": { "cache": true },
    "typecheck:watch": {
      "cache": false,
      "persistent": true
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"]
    }
  }
}
