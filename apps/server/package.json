{
  "name": "@repo/server",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "prebuild": "rimraf dist",
    "build": "bun run scripts/build.ts",
    "start": "bun run dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "lint": "eslint --fix --cache .",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --watch --noEmit",
    "format": "prettier --write --no-error-on-unmatched-pattern --ignore-path .gitignore --ignore-path .prettierignore  --cache ."
  },
  "exports": {
    "./app": {
      "types": "./src/app.ts"
    }
  },
  "dependencies": {
    "@hono/zod-validator": "0.7.6",
    "@react-email/components": "1.0.12",
    "@react-email/render": "2.0.8",
    "better-auth": "1.6.19",
    "bullmq": "5.78.1",
    "croner": "10.0.1",
    "dayjs": "1.11.21",
    "dotenv": "17.4.2",
    "drizzle-kit": "0.31.10",
    "drizzle-orm": "0.45.2",
    "file-type": "22.0.1",
    "filenamify": "7.0.1",
    "hono": "4.12.25",
    "hono-rate-limiter": "0.5.3",
    "ioredis": "5.11.1",
    "minio": "8.0.7",
    "nanoid": "5.1.11",
    "nodemailer": "9.0.0",
    "pino": "10.3.1",
    "pino-loki": "3.0.0",
    "pino-pretty": "13.1.3",
    "rimraf": "6.1.3",
    "sharp": "0.35.1",
    "thread-stream": "4.2.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@repo/config": "workspace:*",
    "@types/bun": "1.3.14",
    "@types/node": "25.9.3",
    "@types/nodemailer": "8.0.1",
    "@types/react": "19.2.17",
    "eslint": "9.39.1",
    "react": "19.2.7",
    "typescript": "6.0.3"
  }
}
