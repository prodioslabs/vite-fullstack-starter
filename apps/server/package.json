{
  "name": "@repo/server",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun run scripts/build.ts",
    "start": "bun run dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "lint": "eslint --fix --cache .",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --watch --noEmit",
    "format": "prettier --write --no-error-on-unmatched-pattern --ignore-path .gitignore --ignore-path .prettierignore  --cache ."
  },
  "exports": {
    "./app": {
      "types": "./src/app.ts"
    }
  },
  "dependencies": {
    "@hono/zod-validator": "0.7.6",
    "better-auth": "1.5.6",
    "bullmq": "5.73.0",
    "croner": "10.0.1",
    "dayjs": "1.11.20",
    "dotenv": "17.4.0",
    "drizzle-kit": "0.31.10",
    "drizzle-orm": "0.45.2",
    "file-type": "22.0.1",
    "filenamify": "7.0.1",
    "hono": "4.12.11",
    "ioredis": "5.10.1",
    "minio": "8.0.7",
    "nanoid": "5.1.7",
    "pino": "10.3.1",
    "pino-loki": "3.0.0",
    "pino-pretty": "13.1.3",
    "sharp": "0.34.5",
    "thread-stream": "4.0.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@repo/config": "workspace:*",
    "@types/bun": "1.3.11",
    "@types/node": "25.5.1",
    "eslint": "9.39.1",
    "typescript": "6.0.2"
  }
}
