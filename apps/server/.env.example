# -----------------------------------------------------------------------------
# Runtime subsystems (set to "true" or "false")
# -----------------------------------------------------------------------------
ENABLE_HTTP_SERVER=true
ENABLE_QUEUE_WORKERS=true
ENABLE_CRON=true

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vite_fullstack_starter

# -----------------------------------------------------------------------------
# Auth & URLs
# -----------------------------------------------------------------------------
CORS_ORIGIN=http://localhost:5173
BETTER_AUTH_URL=http://localhost:3000
APP_BASE_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# Health checks
# -----------------------------------------------------------------------------
HEALTHCHECK_API_KEY=change-me-to-a-secret-at-least-32-chars

# -----------------------------------------------------------------------------
# Redis (used for rate limiting and BullMQ workers)
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_USERNAME=
# REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# Object storage (MinIO defaults match docker/docker-compose.yaml)
# -----------------------------------------------------------------------------
S3_ENDPOINT=localhost
S3_PORT=9000
S3_USE_SSL=false
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=upload
# S3_REGION=

# -----------------------------------------------------------------------------
# Email (optional — required for password reset emails)
# -----------------------------------------------------------------------------
SMTP_USER=invalid@email.com
SMTP_PASSWORD=invalid_password

# -----------------------------------------------------------------------------
# Logging (optional — Grafana Loki)
# -----------------------------------------------------------------------------
# LOKI_HOST=http://localhost:3100
# LOKI_USERNAME=
# LOKI_PASSWORD=
